{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}"
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
    },
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "release",
      "hidden": true,
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "debug",
      "hidden": true,
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "ninja_debug_vcpkg",
      "inherits": [ "base", "vcpkg", "ninja", "debug" ],
      "displayName": "ninja debug config with vcpkg",
      "description": "Configure with vcpkg toolchain"
    },
    {
      "name": "ninja_release_vcpkg",
      "inherits": [ "base", "vcpkg", "ninja", "release" ],
      "displayName": "ninja release config with vcpkg",
      "description": "Configure with vcpkg toolchain"
    },
    {
      "name": "ninja_debug",
      "inherits": [ "base", "ninja", "debug" ],
      "displayName": "Ninja Debug Config",
      "description": "Configure with vcpkg toolchain"
    },
    {
      "name": "ninja_release",
      "inherits": [ "base", "ninja", "release" ],
      "displayName": "Ninja Release Config",
      "description": "Configure with vcpkg toolchain"
    },
    {
      "hidden": true,
      "name": "Qt",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      },
      "vendor": {
        "qt-project.org/Qt": {
          "checksum": "wVa86FgEkvdCTVp1/nxvrkaemJc="
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ninja_debug_vcpkg_build",
      "configurePreset": "ninja_debug_vcpkg",
      "displayName": "Build Debug with vcpkg",
      "description": "Build Debug with Ninja and vcpkg",
      "configuration": "Debug"
    },
    {
      "name": "ninja_release_vcpkg_build",
      "configurePreset": "ninja_release_vcpkg",
      "displayName": "Build Release with vcpkg",
      "description": "Build Release with Ninja and vcpkg",
      "configuration": "Release"
    },
    {
      "name": "ninja_debug_build",
      "configurePreset": "ninja_debug",
      "displayName": "Build Debug",
      "description": "Build Debug with Ninja",
      "configuration": "Debug"
    },
    {
      "name": "ninja_release_build",
      "configurePreset": "ninja_release",
      "displayName": "Build Release",
      "description": "Build Release with Ninja",
      "configuration": "Release"
    }
  ],
  "vendor": {
    "qt-project.org/Presets": {
      "checksum": "LHD+rwGO7ojCbP4bVbiXmRMVGBc="
    }
  }
}