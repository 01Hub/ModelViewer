      <item row="1" column="2" colspan="2">
       <widget class="QDoubleSpinBox" name="spinScaleU">
        <property name="toolTip">
         <string>&lt;html&gt;&lt;head/&gt;&lt;body&gt;&lt;p&gt;Texture scale in U direction&lt;/p&gt;&lt;p&gt;Default: 1.0 (no scaling).&lt;/p&gt;&lt;p&gt;Range: Any non-zero floating-point number. &lt;/p&gt;&lt;p&gt;Usage: Defines the scale factor applied to the U coordinates. &lt;/p&gt;&lt;p&gt;A scale of 2.0 causes the texture to repeat twice, while a scale of 0.5 stretches it. Negative values can be used to flip textures&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
        </property>
        <property name="decimals">
         <number>3</number>
        </property>
        <property name="minimum">
         <double>-100.000000000000000</double>
        </property>
        <property name="maximum">
